import streamlit as st
import pandas as pd
import io

# إعدادات الصفحة
st.set_page_config(page_title="نظام تسكين الغرف الذكي", layout="wide")

# تنسيق الواجهة لتدعم اللغة العربية من اليمين لليسار
st.markdown("""
    <style>
    body { text-align: right; direction: rtl; }
    div[data-testid="stBlock"] { text-align: right; direction: rtl; }
    .stTextInput>div>div>input { text-align: right; direction: rtl; }
    .stTextArea>div>div>textarea { text-align: right; direction: rtl; }
    .stNumberInput>div>div>input { text-align: right; direction: rtl; }
    </style>
""", unsafe_allow_html=True)

st.title("🏨 نظام التسكين وإدارة الغرف الذكي")
st.write("تحكم في الغرف، سكن النزلاء تلقائياً، وقم بتحميل النتيجة في ملف إكسيل بضغطة زر.")

# حفظ الغرف الافتراضية في الذاكرة المؤقتة للتطبيق
if "hotel_rooms" not in st.session_state:
    default_rooms = []
    default_rooms.append({"id": "غرفة رقم 1", "capacity": 8})
    default_rooms.append({"id": "غرفة رقم 2", "capacity": 7})
    for i in range(1, 14):
        default_rooms.append({"id": f"غرفة رقم {i+2}", "capacity": 5})
    for i in range(1, 3):
        default_rooms.append({"id": f"غرفة رقم {i+15}", "capacity": 4})
    st.session_state.hotel_rooms = default_rooms

col1, col2 = st.columns()

# --- لوحة التحكم في الغرف ---
with col1:
    st.header("🛠️ إدارة وتعديل الغرف")
    
    with st.expander("➕ إضافة غرفة جديدة أو تعديل سعة", expanded=False):
        new_room_name = st.text_input("اسم أو رقم الغرفة:", placeholder="مثال: غرفة 18")
        new_room_beds = st.number_input("عدد السراير:", min_value=1, max_value=50, value=5)
        if st.button("حفظ الغرفة"):
            if new_room_name:
                if any(r["id"] == new_room_name for r in st.session_state.hotel_rooms):
                    st.error("⚠️ الاسم موجود بالفعل.")
                else:
                    st.session_state.hotel_rooms.append({"id": new_room_name, "capacity": new_room_beds})
                    st.success(f"✅ تم إضافة {new_room_name}")
                    st.rerun()
            else:
                st.error("يرجى كتابة الاسم.")

    rooms_df = pd.DataFrame(st.session_state.hotel_rooms)
    total_beds = int(rooms_df["capacity"].sum())
    
    st.info(f"إجمالي الغرف: **{len(rooms_df)}** | إجمالي السراير: **{total_beds}**")
    
    room_to_delete = st.selectbox("❌ حذف غرفة:", ["-- اختر غرفة لحذفها --"] + [r["id"] for r in st.session_state.hotel_rooms])
    if room_to_delete != "-- اختر غرفة لحذفها --":
        if st.button("تأكيد الحذف"):
            st.session_state.hotel_rooms = [r for r in st.session_state.hotel_rooms if r["id"] != room_to_delete]
            st.success("🗑️ تم الحذف بنجاح.")
            st.rerun()

    st.dataframe(rooms_df.rename(columns={"id": "اسم الغرفة", "capacity": "عدد السراير"}), use_container_width=True, hide_index=True)

# --- التسكين وحفظ الملف ---
with col2:
    st.header("👥 تسكين النزلاء")
    
    guests_input = st.text_area("أدخل أسماء النزلاء (اسم واحد في كل سطر):", height=150, placeholder="محمد أحمد\nعلي حسن...")
    
    if guests_input:
        guests = [g.strip() for g in guests_input.replace(",", "\n").split("\n") if g.strip()]
        num_guests = len(guests)
        st.metric(label="عدد النزلاء المطلوب تسكينهم", value=f"{num_guests} فرد")

        if st.button("🚀 ابدأ التسكين التلقائي", type="primary"):
            sorted_rooms = sorted(st.session_state.hotel_rooms, key=lambda x: x["capacity"], reverse=True)
            room_assignments = {r["id"]: {"capacity": r["capacity"], "guests": []} for r in sorted_rooms}
            
            guest_index = 0
            for room in sorted_rooms:
                r_id = room["id"]
                cap = room["capacity"]
                while len(room_assignments[r_id]["guests"]) < cap and guest_index < num_guests:
                    room_assignments[r_id]["guests"].append(guests[guest_index])
                    guest_index += 1
            
            report_data = []
            for r_id, info in room_assignments.items():
                status = "مكتملة" if len(info["guests"]) == info["capacity"] else "متاح بها أماكن"
                if len(info["guests"]) == 0: status = "فارغة"
                
                report_data.append({
                    "اسم الغرفة": r_id,
                    "إجمالي السراير": info["capacity"],
                    "عدد المسكنين فعلياً": len(info["guests"]),
                    "حالة الغرفة": status,
                    "أسماء النزلاء داخل الغرفة": ", ".join(info["guests"]) if info["guests"] else "لا يوجد"
                })
            
            final_df = pd.DataFrame(report_data)
            st.subheader("📋 كشف التوزيع الناتجة:")
            st.dataframe(final_df, use_container_width=True, hide_index=True)
            
            # خوارزمية حفظ وتحويل البيانات إلى ملف إكسيل حقيقي (xlsx)
            buffer = io.BytesIO()
            with pd.ExcelWriter(buffer, engine='openpyxl') as writer:
                final_df.to_excel(writer, index=False, sheet_name="كشف التسكين")
            buffer.seek(0)
            
            # زر التحميل
            st.download_button(
                label="📥 تحميل كشف التسكين النهائي بصيغة Excel",
                data=buffer,
                file_name="توزيع_الغرف_والنزلاء.xlsx",
                mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
            )
            
            if guest_index < num_guests:
                st.error(f"🚨 متبقي {num_guests - guest_index} نزيل بدون غرف لعدم وجود سراير كافية.")
                st.write(", ".join(guests[guest_index:]))
